# Production environment. Copy to .env.prod on the server and fill secrets.
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=14

# Comma-separated list of allowed web origins for CORS — pin them, never `*`.
API_CORS_ORIGINS=https://YOUR_DOMAIN

# Postgres — usually a managed instance. Values below are for a co-located container.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=protocol_ai
POSTGRES_USER=protocol
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://protocol:CHANGE_ME@postgres:5432/protocol_ai
ALEMBIC_DATABASE_URL=postgresql+psycopg://protocol:CHANGE_ME@postgres:5432/protocol_ai

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# S3 — consider AWS/GCP/Yandex for prod; MinIO co-located is fine for small deployments.
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=https://YOUR_DOMAIN/s3
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET_MEDIA=protocol-media
S3_BUCKET_EXPORTS=protocol-exports

HUGGINGFACE_TOKEN=hf_CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_FALLBACK=qwen2.5:14b

# ASR provider — openai (cloud, best Kazakh quality, paid) or local (on-box GPU).
ASR_PROVIDER=openai
OPENAI_ASR_MODEL=gpt-4o-transcribe
OPENAI_ASR_FALLBACK=whisper-1
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# Local fallback — GPU required for acceptable latency.
ASR_MODEL=large-v3
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16
ASR_KAZAKH_MODEL=issai/whisper-large-v3-kazakh
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN
NEXT_PUBLIC_WS_URL=wss://YOUR_DOMAIN
NEXT_PUBLIC_DEFAULT_LOCALE=ru
